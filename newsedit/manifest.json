{
  "manifest_version": 3,
  "name": "NewsedIt - SERVPRO CRM Note Assistant",
  "version": "1.0.0",
  "description": "Auto-fill and post CRM notes to SERVPRO Dash CRM using the 5-part PM note formula",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://servepro.ngsapps.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "NewsedIt - SERVPRO Note Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://servepro.ngsapps.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
